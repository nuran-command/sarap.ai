APP_NAME=Sarap.ai
APP_ENV=development
SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Local development defaults to SQLite if DATABASE_URL is omitted.
# Production should use PostgreSQL.
DATABASE_URL=postgresql+psycopg2://sarap:sarap@localhost:5432/sarap

# Optional. If omitted, backend uses deterministic local MVP analysis/replies.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=local

