# App settings
APP_NAME="Sarap.ai B2B SaaS"
DEBUG=true
API_V1_STR="/api/v1"

# Security and Auth
# Generate secure key using: openssl rand -hex 32
JWT_SECRET="7f59d57a91ce30c6a51d95013be88cf3b2ac9108c90967ab329241b12b5b8281"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database Connectivity
# For local run without Docker: postgresql://sarap_user:sarap_secure_password_2026@localhost:5432/sarap_db
# For Docker run: postgresql://sarap_user:sarap_secure_password_2026@db:5432/sarap_db
DATABASE_URL="postgresql://sarap_user:sarap_secure_password_2026@localhost:5432/sarap_db"

# AI Integration
OPENAI_API_KEY="your-openai-api-key-here"

# Seed Admin Account
